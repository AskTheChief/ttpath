rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — authenticated users read/write their own profile only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Tribes — public read (for the map), members can leave
    match /tribes/{tribeId} {
      allow read: if true;
      allow update: if request.auth != null;
    }

    // Everything else — server-side only (Admin SDK bypasses rules)
    // journal_entries, chat_sessions, meeting_reports, tribe_applications,
    // inbound_emails, outbound_emails, email_templates, user_tutorials,
    // tutorial_feedback, content, processed_reports, body_feelings_maps

    // Chat sessions — authenticated read (dev-den admin page uses client SDK)
    match /chat_sessions/{docId} {
      allow read: if request.auth != null;
    }

    // Content — public read (Communication Model principles)
    match /content/{docId} {
      allow read: if true;
    }

    // Body feelings map game — authenticated users
    match /body_feelings_maps/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
