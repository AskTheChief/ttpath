rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for all images under faq_images
    match /faq_images/{allPaths=**} {
      allow read;
    }
    // Only allow authenticated users to write to their own user-specific folder
    match /faq_images/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
